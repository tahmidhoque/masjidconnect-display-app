#!/usr/bin/env bash
# =============================================================================
# MasjidConnect Kiosk — xinit client script for minimal X11 image.
# Run by xinit as the client after the X server starts (e.g. xinit this-file -- :0 vt1).
# If no internet is detected, shows a WiFi setup GUI before launching the kiosk.
# Disables screen sleep, hides cursor, waits for display server, then launches Chromium.
# =============================================================================

set -euo pipefail

PORT="${PORT:-3001}"
URL="http://localhost:${PORT}"
WIFI_SETUP_PORT="${WIFI_SETUP_PORT:-3002}"
WIFI_FLAG="/tmp/masjidconnect-wifi-done"
WIFI_STATE_DIR="/var/lib/masjidconnect"
WIFI_CONNECTED_MARKER="${WIFI_STATE_DIR}/wifi-connected-once"
WIFI_HOTSPOT_ACTIVE_MARKER="/tmp/masjidconnect-hotspot-active"

# Log for debugging: from another machine run:
#   ssh pi@<Pi-IP> "cat /tmp/kiosk.log"
# Or from a TTY on the Pi (Ctrl+Alt+F2): cat /tmp/kiosk.log
KIOSK_LOG="/tmp/kiosk.log"
log() { echo "$(date '+%Y-%m-%d %H:%M:%S') $*" >> "$KIOSK_LOG" 2>/dev/null || true; }
: >> "$KIOSK_LOG" 2>/dev/null || true
log "xinitrc-kiosk started (user=$(whoami) DISPLAY=${DISPLAY:-:0})"

# Disable DPMS (screen sleep) and screen saver
xset s off 2>/dev/null || true
xset -dpms 2>/dev/null || true
xset s noblank 2>/dev/null || true

# Branded background so there is no black/grey flash during startup.
xsetroot -solid '#0A2647' 2>/dev/null || true
if command -v feh &>/dev/null && [ -f /opt/masjidconnect/background.png ]; then
  feh --bg-center --image-bg '#0A2647' /opt/masjidconnect/background.png 2>/dev/null &
fi

# Tell Plymouth to hand the display to X and hold its last frame until we paint
# over it. Without this, Plymouth times out and the raw VT is briefly visible.
/bin/plymouth quit --retain-splash 2>/dev/null || true

# Hide the mouse cursor after 0.5s of inactivity
if command -v unclutter &>/dev/null; then
  unclutter -idle 0.5 -root &
fi

# =============================================================================
# Display size detection — done early so ALL Chromium instances (Wi-Fi setup
# AND main kiosk) use the correct --window-size and fill the screen.
# =============================================================================
export DISPLAY="${DISPLAY:-:0}"
export XAUTHORITY="${HOME:-/tmp}/.Xauthority"

WINDOW_SIZE="1920,1080"
if command -v xrandr &>/dev/null; then
  DIM=$(xrandr --current 2>/dev/null | sed -n 's/.* current \([0-9]*\) x \([0-9]*\).*/\1,\2/p' | head -1)
  if [ -n "$DIM" ] && [ "$DIM" != "," ]; then
    WINDOW_SIZE="$DIM"
  fi
fi
if [ "$WINDOW_SIZE" = "1920,1080" ] && command -v xdpyinfo &>/dev/null; then
  DIM=$(xdpyinfo 2>/dev/null | grep 'dimensions:' | head -1 | awk '{print $2}' | tr 'x' ',')
  [ -n "$DIM" ] && WINDOW_SIZE="$DIM"
fi
log "Display size: $WINDOW_SIZE"

# Resolve Chromium binary once — used for both Wi-Fi setup and main kiosk.
CHROMIUM=""
if command -v chromium-browser &>/dev/null; then
  CHROMIUM="chromium-browser"
elif command -v chromium &>/dev/null; then
  CHROMIUM="chromium"
else
  log "ERROR: Chromium not found"
  exit 1
fi

# Helper: launch Chromium filling the full screen (Wi-Fi setup pages).
# Usage: launch_chromium_fullscreen <url> <profile_dir>
launch_chromium_fullscreen() {
  local url="$1"
  local profile="$2"
  mkdir -p "$profile" 2>/dev/null || true
  # stdout AND stderr must go to /dev/null. If stdout stays connected to the
  # calling $(...) pipe, the command substitution blocks until Chromium exits,
  # which hangs the entire script.
  env DBUS_SESSION_BUS_ADDRESS= "$CHROMIUM" \
    --kiosk \
    --start-fullscreen \
    --start-maximized \
    --window-position=0,0 \
    --window-size="${WINDOW_SIZE}" \
    --no-first-run \
    --user-data-dir="$profile" \
    --noerrdialogs \
    --disable-infobars \
    --disable-sync \
    --password-store=basic \
    --disable-dev-shm-usage \
    --force-device-scale-factor=1 \
    --disable-session-crashed-bubble \
    --disable-component-update \
    --blink-settings=defaultBackgroundColor=4278855239 \
    "$url" >/dev/null 2>&1 &
  echo $!
}

# =============================================================================
# Connectivity + Wi-Fi hotspot setup
# =============================================================================
HOTSPOT_SCRIPT="/opt/masjidconnect/deploy/wifi-hotspot.sh"
WIFI_SETUP_SERVER="/opt/masjidconnect/deploy/wifi-setup-server.mjs"

have_connectivity() {
  if curl -sf --connect-timeout 4 -o /dev/null "https://portal.masjidconnect.co.uk" 2>/dev/null; then
    return 0
  fi
  if ping -c 1 -W 3 8.8.8.8 >/dev/null 2>&1; then
    return 0
  fi
  return 1
}

# Mark that we've had successful connectivity (persists across reboots).
# Used to distinguish first-time setup from "known wifi but temporarily offline".
mark_wifi_connected() {
  mkdir -p "$WIFI_STATE_DIR" 2>/dev/null || true
  [ -d "$WIFI_STATE_DIR" ] && touch "$WIFI_CONNECTED_MARKER" 2>/dev/null || true
}

# Known-wifi-offline: we had connectivity before (marker exists) but are offline now.
# Use serial setup for first run; use parallel (display + background hotspot) for reconnect.
known_wifi_offline() {
  [ -f "$WIFI_CONNECTED_MARKER" ] && ! have_connectivity
}

# Log network state for diagnostics
log "Network state at X start:"
log "  route: $(ip route show default 2>/dev/null | head -1 || echo none)"
log "  rfkill: $(rfkill list 2>/dev/null | head -5 || echo 'rfkill unavailable')"
log "  iw dev: $(iw dev 2>/dev/null | head -5 || echo 'none')"

# Allow a couple of seconds for the network stack to settle after X starts
sleep 2

# Force Wi-Fi setup for testing (skip connectivity check):
#   ssh pi@<Pi-IP> "touch /tmp/masjidconnect-force-wifi-setup && sudo reboot"
FORCE_WIFI_SETUP=false
[ -f /tmp/masjidconnect-force-wifi-setup ] && FORCE_WIFI_SETUP=true
[ "${MASJIDCONNECT_FORCE_WIFI_SETUP:-0}" = "1" ] && FORCE_WIFI_SETUP=true
[ "$FORCE_WIFI_SETUP" = true ] && log "FORCE_WIFI_SETUP enabled"

# PIDs of any setup-phase Chromium instances. Kept alive through the AP teardown
# and display-server wait so the user always sees branded content during the
# transition — killed just before the main kiosk Chromium paints.
INSTRUCTIONS_PID=""
NOWIFI_PID=""

if [ "$FORCE_WIFI_SETUP" = true ] || ! have_connectivity; then
  [ "$FORCE_WIFI_SETUP" = false ] && log "No internet — starting Wi-Fi setup"
  rm -f "$WIFI_FLAG"

  # Update marker when we have connectivity (e.g. forced setup with working network)
  have_connectivity && mark_wifi_connected

  # State machine: first-run (serial) vs known-wifi-offline (parallel)
  KNOWN_WIFI_OFFLINE=false
  if [ "$FORCE_WIFI_SETUP" = false ] && known_wifi_offline; then
    KNOWN_WIFI_OFFLINE=true
    log "Known Wi-Fi offline — parallel path (display + background hotspot)"
  fi

  # ------------------------------------------------------------------
  # PARALLEL PATH: known wifi worked before, now offline. Start display
  # immediately with stale content; run hotspot in background so user
  # can reconnect from phone without blocking the screen.
  # ------------------------------------------------------------------
  if [ "$KNOWN_WIFI_OFFLINE" = true ]; then
    rfkill unblock wifi 2>/dev/null || true
    rfkill unblock wlan 2>/dev/null || true
    rfkill unblock all  2>/dev/null || true
    sleep 1

    WLAN_IFACE=$(iw dev 2>/dev/null | awk '/^\tInterface / {print $2; exit}')
    [ -z "$WLAN_IFACE" ] && WLAN_IFACE=$(ls -d /sys/class/net/wlan* 2>/dev/null | head -1 | xargs basename)
    [ -z "$WLAN_IFACE" ] && WLAN_IFACE=$(ip -o link show 2>/dev/null | awk -F': ' '{print $2}' | grep -E '^(wlan|wlp|wlx)' | head -1)

    if [ -n "$WLAN_IFACE" ] && [ -f "$HOTSPOT_SCRIPT" ] && [ -f "$WIFI_SETUP_SERVER" ]; then
      export WIFI_HOTSPOT_IFACE="$WLAN_IFACE"
      log "Parallel: starting background hotspot on $WLAN_IFACE"
      touch "$WIFI_HOTSPOT_ACTIVE_MARKER" 2>/dev/null || true
      (
        sudo "$HOTSPOT_SCRIPT" scan "$WLAN_IFACE" >>"$KIOSK_LOG" 2>&1 || true
        sudo "$HOTSPOT_SCRIPT" start "$WLAN_IFACE" >>"$KIOSK_LOG" 2>&1 || true
        sleep 1
        sudo "$WIFI_SETUP_SERVER" --ap-mode --iface="$WLAN_IFACE" >>"$KIOSK_LOG" 2>&1
      ) &
      log "Parallel: hotspot and setup server running in background"
    else
      log "Parallel: no wlan interface, skipping background hotspot"
      rm -f "$WIFI_HOTSPOT_ACTIVE_MARKER" 2>/dev/null || true
    fi
    # Fall through to main kiosk launch — do not wait for connectivity
  else
  # ------------------------------------------------------------------
  # SERIAL PATH: first run or no known wifi. Block until setup complete.
  # ------------------------------------------------------------------
  # RPi 4 and RPi 5: unblock rfkill FIRST. On RPi 5 the built-in Wi-Fi
  # (CYW43455 over PCIe) is often soft-blocked until explicitly unblocked,
  # which prevents iw/ip from showing any wireless interface.
  # ------------------------------------------------------------------
  rfkill unblock wifi 2>/dev/null || true
  rfkill unblock wlan 2>/dev/null || true
  rfkill unblock all  2>/dev/null || true
  sleep 1

  # Find the wireless interface. iw dev lists all; also fall back to scanning
  # /sys/class/net for any interface the kernel exposes as type "wlan".
  # Retry for up to 30 s (RPi 5 driver can be slow to register after unblock).
  HAS_WLAN=false
  WLAN_IFACE=""

  find_wlan_iface() {
    # Method 1: iw dev (most reliable when driver is loaded)
    local iface
    iface=$(iw dev 2>/dev/null | awk '/^\tInterface / {print $2; exit}')
    [ -n "$iface" ] && { echo "$iface"; return 0; }

    # Method 2: scan /sys/class/net for wireless_mode marker
    for f in /sys/class/net/*/wireless; do
      [ -e "$f" ] || continue
      iface=$(basename "$(dirname "$f")")
      ip link show "$iface" &>/dev/null && { echo "$iface"; return 0; }
    done

    # Method 3: any interface whose name starts with wlan or wlp or wlx
    for iface in $(ip -o link show 2>/dev/null | awk -F': ' '{print $2}' | grep -E '^(wlan|wlp|wlx)'); do
      echo "$iface"; return 0
    done

    return 1
  }

  for attempt in $(seq 1 15); do
    WLAN_IFACE=$(find_wlan_iface 2>/dev/null || true)
    if [ -n "$WLAN_IFACE" ]; then
      HAS_WLAN=true
      log "Wireless interface '$WLAN_IFACE' found (attempt $attempt)"
      break
    fi
    log "  attempt $attempt: no wlan interface yet (rfkill: $(rfkill list 2>/dev/null | grep -c 'Soft blocked: yes' || echo '?') soft-blocked)"
    sleep 2
  done

  if [ "$HAS_WLAN" = false ]; then
    log "No wireless interface after 30s — showing no-Wi-Fi screen"
    log "  iw dev: $(iw dev 2>/dev/null || echo 'empty')"
    log "  rfkill: $(rfkill list 2>/dev/null || echo 'unavailable')"
    log "  ip link: $(ip -o link show 2>/dev/null | head -10)"
  fi

  # ------------------------------------------------------------------
  # Hotspot path: we have a wireless interface
  # ------------------------------------------------------------------
  if [ "$HAS_WLAN" = true ] && [ -f "$HOTSPOT_SCRIPT" ] && [ -f "$WIFI_SETUP_SERVER" ]; then
    export WIFI_HOTSPOT_IFACE="$WLAN_IFACE"
    log "Using interface: $WIFI_HOTSPOT_IFACE"

    log "Pre-scanning networks..."
    sudo "$HOTSPOT_SCRIPT" scan "$WIFI_HOTSPOT_IFACE" >>"$KIOSK_LOG" 2>&1 \
      || log "  scan failed (non-fatal)"

    log "Starting MasjidConnect-Setup hotspot..."
    sudo "$HOTSPOT_SCRIPT" start "$WIFI_HOTSPOT_IFACE" >>"$KIOSK_LOG" 2>&1 \
      || log "  hotspot start failed (non-fatal)"
    sleep 1

    # Start setup server in AP mode (port 80, all interfaces).
    # Run via its shebang (not "sudo node ...") — the sudoers rule grants NOPASSWD
    # for the script path directly, and args avoid sudo env-var restrictions.
    sudo "$WIFI_SETUP_SERVER" --ap-mode --iface="$WIFI_HOTSPOT_IFACE" >>"$KIOSK_LOG" 2>&1 &
    WIFI_SERVER_PID=$!
    log "Wi-Fi setup server PID=$WIFI_SERVER_PID"

    SERVER_READY=false
    for i in $(seq 1 30); do
      curl -sf -o /dev/null "http://localhost/api/status" 2>/dev/null \
        && { SERVER_READY=true; break; }
      sleep 0.5
    done
    log "Setup server ready=$SERVER_READY"

    if [ "$SERVER_READY" = true ]; then
      INSTRUCTIONS_PID=$(launch_chromium_fullscreen \
        "http://localhost/instructions" \
        "${HOME:-/tmp}/.config/chromium-wifi-setup")
      log "Instructions page (Chromium PID=$INSTRUCTIONS_PID)"
    fi

    log "Waiting for Wi-Fi config (timeout 300s)..."
    for i in $(seq 1 300); do
      [ -f "$WIFI_FLAG" ] && { log "Flag file set"; break; }
      have_connectivity && { log "Connectivity detected"; break; }
      sleep 1
    done

    # Keep INSTRUCTIONS_PID alive — we kill it just before the main kiosk
    # opens so the user sees branded content all through the AP teardown and
    # display-server wait rather than a bare dark root window.
    # Server runs as root (via sudo) — need sudo to kill it, plus any child node process
    if [ -n "$WIFI_SERVER_PID" ]; then
      sudo kill "$WIFI_SERVER_PID" 2>/dev/null || true
      sudo pkill -f "wifi-setup-server" 2>/dev/null || true
    fi
    sudo "$HOTSPOT_SCRIPT" stop "$WIFI_HOTSPOT_IFACE" >>"$KIOSK_LOG" 2>&1 || true
    rm -f "$WIFI_FLAG"

    if ! have_connectivity; then
      log "Waiting for network after AP teardown..."
      for i in $(seq 1 15); do
        sleep 1
        have_connectivity && break
      done
    fi

    have_connectivity && mark_wifi_connected
    log "Wi-Fi setup done (connected=$(have_connectivity && echo yes || echo no))"

  # ------------------------------------------------------------------
  # No Wi-Fi path: show a branded screen with "connect via Ethernet" message
  # ------------------------------------------------------------------
  else
    log "No wlan interface — showing no-Wi-Fi screen"
    WIFI_SERVER_PID=""
    if [ -f "$WIFI_SETUP_SERVER" ]; then
      node "$WIFI_SETUP_SERVER" >>"$KIOSK_LOG" 2>&1 &
      WIFI_SERVER_PID=$!
      for i in $(seq 1 20); do
        curl -sf -o /dev/null "http://127.0.0.1:${WIFI_SETUP_PORT}/api/status" 2>/dev/null \
          && break
        sleep 0.5
      done
      NOWIFI_PID=$(launch_chromium_fullscreen \
        "http://127.0.0.1:${WIFI_SETUP_PORT}/no-wifi" \
        "${HOME:-/tmp}/.config/chromium-wifi-setup")
      log "No-Wi-Fi screen (Chromium PID=$NOWIFI_PID)"

      for i in $(seq 1 300); do
        [ -f "$WIFI_FLAG" ] && break
        have_connectivity && break
        sleep 1
      done

      # Keep NOWIFI_PID alive for the same reason as INSTRUCTIONS_PID above.
      if [ -n "$WIFI_SERVER_PID" ]; then
        kill "$WIFI_SERVER_PID" 2>/dev/null || true
        sudo pkill -f "wifi-setup-server" 2>/dev/null || true
      fi
      have_connectivity && mark_wifi_connected
      rm -f "$WIFI_FLAG"
    fi
  fi

  rm -f /tmp/masjidconnect-force-wifi-setup
  fi
else
  mark_wifi_connected
  log "Internet available — skipping Wi-Fi setup"
fi

# =============================================================================
# Main kiosk launch
# =============================================================================

# Wait for the display server (node static server) to be ready
for i in $(seq 1 90); do
  curl -sf "${URL}/health" >/dev/null 2>&1 && break
  sleep 1
done

# Brief delay so X/DRM is fully ready
sleep 1

# Kill any setup-phase Chromium now — main kiosk is about to paint.
# Doing it here (rather than during AP teardown) keeps branded content on
# screen all through the network-settle and display-server-wait periods.
[ -n "$INSTRUCTIONS_PID" ] && kill "$INSTRUCTIONS_PID" 2>/dev/null || true
[ -n "$NOWIFI_PID" ]       && kill "$NOWIFI_PID"       2>/dev/null || true

log "Starting Chromium kiosk (DISPLAY=$DISPLAY, size=$WINDOW_SIZE)"

CHROMIUM_USER_DATA="${HOME:-/tmp}/.config/chromium-kiosk"
mkdir -p "${CHROMIUM_USER_DATA}" 2>/dev/null || true

CHROMIUM_GPU_FLAGS="--enable-gpu-rasterization --enable-oop-rasterization"
[ "${KIOSK_DISABLE_GPU:-0}" = "1" ] && CHROMIUM_GPU_FLAGS="--disable-gpu"

while true; do
  env DBUS_SESSION_BUS_ADDRESS= "${CHROMIUM}" \
    --kiosk \
    --start-fullscreen \
    --start-maximized \
    --window-position=0,0 \
    --window-size="${WINDOW_SIZE}" \
    --noerrdialogs \
    --disable-infobars \
    --no-first-run \
    --disable-sync \
    --disable-signin-profile-creation \
    --user-data-dir="${CHROMIUM_USER_DATA}" \
    --check-for-update-interval=31536000 \
    --disable-features=TranslateUI \
    --disable-pinch \
    --overscroll-history-navigation=0 \
    $CHROMIUM_GPU_FLAGS \
    --disable-dev-shm-usage \
    --force-device-scale-factor=1 \
    --autoplay-policy=no-user-gesture-required \
    --disable-session-crashed-bubble \
    --disable-component-update \
    --password-store=basic \
    --renderer-process-limit=1 \
    --disable-background-networking \
    --disable-backgrounding-occluded-windows \
    --blink-settings=defaultBackgroundColor=4278855239 \
    "${URL}" || true
  log "Chromium exited, restarting in 5s"
  sleep 5
done
